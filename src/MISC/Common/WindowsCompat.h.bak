// =============================================================================
// WinMgr.h: SetRect method naming conflict (WindowsCompat macro)
/*
The WindowsCompat SetRect macro conflicts with WinMgr.h's SetRect method.
The method has been renamed to setRect via sed substitution in WinMgr.h.
*/

