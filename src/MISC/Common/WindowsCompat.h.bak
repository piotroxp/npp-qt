// =============================================================================
// Stub function declarations - called by ScopedCOMInit and others
// (No #ifndef guard — these are inline and idempotent)
// =============================================================================
// COM / Shell stubs used across the codebase
inline void CoInitializeEx(void*, unsigned long) {}
inline void CoUninitialize() {}
inline int MessageBox(void*, const wchar_t*, const wchar_t*, unsigned int) { return IDOK; }
inline bool DestroyMenu(void*) { return true; }
inline bool DestroyWindow(void*) { return true; }
inline bool DestroyIcon(void*) { return true; }
inline bool FreeLibrary(void*) { return true; }
inline bool VerifyVersionInfoW(void*, long, unsigned long) { return true; }

