// =============================================================================
// Basic structures (RECT, POINT, SIZE)
// =============================================================================

#ifndef RECT_DEFINED
#define RECT_DEFINED
struct RECT {
    LONG left;
    LONG top;
    LONG right;
    LONG bottom;
};
#endif

#ifndef POINT_DEFINED
#define POINT_DEFINED
struct POINT {
    LONG x;
    LONG y;
};
#endif

#ifndef SIZE_DEFINED
#define SIZE_DEFINED
struct SIZE {
    LONG cx;
    LONG cy;
};
#endif

// =============================================================================
// DATE and TIME structures
// =============================================================================

#ifndef DATE_DEFINED
#define DATE_DEFINED
typedef double DATE;
#endif

#ifndef FILETIME_DEFINED
#define FILETIME_DEFINED
struct FILETIME {
    DWORD dwLowDateTime;
    DWORD dwHighDateTime;
};
#endif

#ifndef SYSTEMTIME_DEFINED
#define SYSTEMTIME_DEFINED
struct SYSTEMTIME {
    WORD wYear;
    WORD wMonth;
    WORD wDayOfWeek;
    WORD wDay;
    WORD wHour;
    WORD wMinute;
    WORD wSecond;
    WORD wMilliseconds;
};
#endif

#ifndef ULARGE_INTEGER_DEFINED
#define ULARGE_INTEGER_DEFINED
union ULARGE_INTEGER {
    struct { DWORD LowPart; DWORD HighPart; };
    unsigned long long QuadPart;
};
#endif

