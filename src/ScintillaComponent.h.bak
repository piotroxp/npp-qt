    int annotationGetMouseNotification() const { return static_cast<int>(send(SCI_ANNOTATIONGETMOUSENOTIFICATION)); }
    void setWrapVisualFlags(int flags) { send(SCI_SETWRAPVISUALFLAGSLOCATION, flags); }
    int getWrapVisualFlags() const { return static_cast<int>(send(SCI_GETWRAPVISUALFLAGSLOCATION)); }
    void setWrapVisualFlagsStart(int flags) { send(SCI_SETWRAPVISUALFLAGSSTART, flags); }
    int getWrapVisualFlagsStart() const { return static_cast<int>(send(SCI_GETWRAPVISUALFLAGSSTART)); }
    void setWrapVisualFlagsEnd(int flags) { send(SCI_SETWRAPVISUALFLAGSEND, flags); }
    int getWrapVisualFlagsEnd() const { return static_cast<int>(send(SCI_GETWRAPVISUALFLAGSEND)); }
    void setWrapStartIndent(int indent) { send(SCI_SETWRAPSTARTINDENT, indent); }
    int getWrapStartIndent() const { return static_cast<int>(send(SCI_GETWRAPSTARTINDENT)); }
    void setWrapMode(int mode) { send(SCI_SETWRAPMODE, mode); }
    int getWrapMode() const { return static_cast<int>(send(SCI_GETWRAPMODE)); }
    void setPositionCache(int size) { send(SCI_SETPOSITIONCACHE, size); }
    int getPositionCacheSize() const { return static_cast<int>(send(SCI_GETPOSITIONCACHESIZE)); }
    void setDirectAccess(int value) { send(SCI_SETDIRECTACCESS, value); }
    int getDirectAccess() const { return static_cast<int>(send(SCI_GETDIRECTACCESS)); }
    void setMouseDwellTime(int time) { send(SCI_SETMOUSEDWELLTIME, time); }
    int getMouseDwellTime() const { return static_cast<int>(send(SCI_GETMOUSEDWELLTIME)); }
    void setHoverTime(int time) { send(SCI_SETMOUSEHOVERTIME, time); }
    int getHoverTime() const { return static_cast<int>(send(SCI_GETMOUSEHOVERTIME)); }
    void setAccessibility(int mode) { send(SCI_SETACCESSIBILITY, mode); }
    int getAccessibility() const { return static_cast<int>(send(SCI_GETACCESSIBILITY)); }
    int positionAfter(int pos) const { return static_cast<int>(send(SCI_POSITIONAFTER, pos)); }
    int positionBefore(int pos) const { return static_cast<int>(send(SCI_POSITIONBEFORE, pos)); }
    int positionRelative(int pos, int relative) const { return static_cast<int>(send(SCI_POSITIONRELATIVE, pos, relative)); }
    int lineEndPosition(int line) const { return static_cast<int>(send(SCI_GETLINEENDPOSITION, line)); }
    int getColumn(int pos) const { return static_cast<int>(send(SCI_GETCOLUMN, pos)); }
    int countCharacters(int start, int end) const { return static_cast<int>(send(SCI_COUNTCHARACTERS, start, end)); }
    int countCodeUnits(int start, int end) const { return static_cast<int>(send(SCI_COUNTCODEUNITS, start, end)); }
    bool selectionContains(const char* text) const { return send(SCI_SELECTIONCONTAINS, reinterpret_cast<sptr_t>(text)) != 0; }
    void setRepresentationAppearance(const char* encoded, int appearance) { send(SCI_SETREPRESENTATIONAPPEARANCE, reinterpret_cast<sptr_t>(encoded), appearance); }
    int getRepresentationAppearance(const char* encoded) const { return static_cast<int>(send(SCI_GETREPRESENTATIONAPPEARANCE, reinterpret_cast<sptr_t>(encoded))); }
    void setRepresentationColour(const char* encoded, int colour) { send(SCI_SETREPRESENTATIONCOLOUR, reinterpret_cast<sptr_t>(encoded), colour); }
    int getRepresentationColour(const char* encoded) const
};

// Forward type alias: Win32 used ScintillaEditView as the concrete editor class.
// In the Qt6 lift, ScintillaComponent IS that class. Buffer.h forward-declares
// ScintillaEditView, so this alias satisfies those declarations without renaming
// every usage throughout the codebase.
using ScintillaEditView = ScintillaComponent;

// =============================================================================
// ScintillaCtrls
//
// Lifts ScintillaCtrls (Win32) → Qt6 factory/manager for ScintillaComponent instances.
//
// Win32 patterns:
//   HWND createSintilla(HWND hParent)  →  createEditor(QWidget* parent)
//   std::vector<ScintillaEditView*>     →  QVector<ScintillaComponent*>
//   HINSTANCE _hInst                    →  QApplication* (via qApp)
// =============================================================================

class ScintillaCtrls : public QObject
{
    Q_OBJECT

public:
    explicit ScintillaCtrls(QObject* parent = nullptr);
    ~ScintillaCtrls() override;

    // Semantic lift: createSintilla(hParent) → createEditor(parent)
    // Creates a new ScintillaComponent and registers it.
    ScintillaComponent* createEditor(QWidget* parent);

    // Semantic lift: getScintillaEditViewFrom(handle) → editorFromIndex(index)
    ScintillaComponent* editorFromIndex(int index);
    ScintillaComponent* editorFromWidget(QWidget* widget) const;

    // Number of active editor instances
    int count() const { return _editors.size(); }

    // Destroy all editors and clear the list
    void destroyAll();

    // Remove a specific editor
    void removeEditor(ScintillaComponent* editor);

public slots:
    // Propagate dark mode changes to all editors
    void setDarkMode(bool enabled);

private:
    int indexOf(ScintillaComponent* editor) const;

    QVector<ScintillaComponent*> _editors;
};

#endif  // SCINTILLA_COMPONENT_H
